# TPT Infrastructure Engineer — Environment Configuration
# Copy this file to .env and fill in your values before starting the backend.

# Required: 64-character random secret for JWT signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TPT_SECRET_KEY=your-64-character-random-secret-here

# JWT token expiry in minutes (default: 480 = 8 hours)
TPT_TOKEN_EXPIRE_MINUTES=480

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost/tpt_infrastructure

# Frontend origin for CORS (comma-separated list for multiple origins)
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
