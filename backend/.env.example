# TPT Infrastructure Engineer - Environment Configuration
# Copy this file to .env and fill in your actual values

# Application
APP_ENV=development
DEBUG=true
# Optional — auto-generated on startup if not set (sessions won't persist across restarts without this)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost/tpt_infrastructure

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Authentication
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMITS_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Email / SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=false
FROM_EMAIL=notifications@tptengineer.com
APP_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# AI Provider (optional — all features work without this)
# Set AI_PROVIDER to one of: anthropic | grok | openrouter
# Then set AI_API_KEY to the corresponding API key.
# AI_MODEL is optional — sensible defaults are used per provider.
#
# Anthropic (Claude):
#   AI_PROVIDER=anthropic
#   AI_API_KEY=sk-ant-...
#   AI_MODEL=claude-sonnet-4-6          # optional override
#
# xAI Grok:
#   AI_PROVIDER=grok
#   AI_API_KEY=xai-...
#   AI_MODEL=grok-3                     # optional override
#
# OpenRouter (access to 100+ models via one key):
#   AI_PROVIDER=openrouter
#   AI_API_KEY=sk-or-...
#   AI_MODEL=anthropic/claude-sonnet-4-6  # optional override
#
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=