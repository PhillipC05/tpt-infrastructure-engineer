# TPT Infrastructure Engineer - Environment Configuration
# Copy this file to .env and fill in your actual values

# Application
APP_ENV=development
DEBUG=true
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost/tpt_infrastructure

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Authentication
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMITS_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Email / SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=false
FROM_EMAIL=notifications@tptengineer.com
APP_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json